[Unit]
Description=Kismet Wireless Monitor (Argus RF Survey)
After=network.target argus-boot.service
Wants=argus-boot.service

[Service]
Type=simple
User=root
ExecStart=/usr/bin/kismet --no-ncurses
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

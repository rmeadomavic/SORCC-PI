    "/api/wifi-capture/toggle": {
      "post": {
        "description": "Toggle wlan0 between managed (WiFi connectivity) and monitor (Kismet capture).\n\nWhen enabling capture: disconnect WiFi, set monitor mode, add wlan0 to Kismet.\nWhen disabling capture: remove wlan0 from Kismet, restore managed mode, reconnect WiFi.\nLTE + Tailscale remain available throughout.\n\nRuns in a thread pool to avoid blocking the event loop during sleeps/subprocesses.",
        "operationId": "wifi_capture_toggle_api_wifi_capture_toggle_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {

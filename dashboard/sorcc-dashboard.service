[Unit]
Description=SORCC RF Survey Dashboard
After=kismet.service
Wants=kismet.service

[Service]
Type=simple
WorkingDirectory=/opt/sorcc/dashboard
ExecStart=/usr/bin/python3 -m uvicorn app:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
